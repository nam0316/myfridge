<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="장보기 목록 🛒"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_add_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ 추가"
            android:backgroundTint="#4CAF50" />

    </LinearLayout>

    <!-- 통계 정보 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#E3F2FD"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_total_items"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="총 아이템"
                android:textSize="12sp"
                android:textColor="#666666" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#E8F5E8"
            android:padding="12dp"
            android:layout_marginStart="8dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_estimated_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45,000원"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#388E3C" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="예상 금액"
                android:textSize="12sp"
                android:textColor="#666666" />

        </LinearLayout>

    </LinearLayout>

    <!-- 카테고리 탭 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_category_all_shopping"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:text="전체"
                android:textSize="12sp"
                android:backgroundTint="#FF9800" />

            <Button
                android:id="@+id/btn_category_vegetables"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:text="채소"
                android:textSize="12sp"
                android:backgroundTint="#9E9E9E" />

            <Button
                android:id="@+id/btn_category_meat"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:text="육류"
                android:textSize="12sp"
                android:backgroundTint="#9E9E9E" />

            <Button
                android:id="@+id/btn_category_dairy"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:text="유제품"
                android:textSize="12sp"
                android:backgroundTint="#9E9E9E" />

            <Button
                android:id="@+id/btn_category_snacks"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="간식"
                android:textSize="12sp"
                android:backgroundTint="#9E9E9E" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- 장보기 목록 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 장보기 아이템 1 -->
            <LinearLayout
                android:id="@+id/shopping_item_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:elevation="2dp">

                <CheckBox
                    android:id="@+id/checkbox_item_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="우유 1L"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="유제품 • 약 3,000원"
                        android:textSize="12sp"
                        android:textColor="#666666" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="수량: 1개"
                    android:textSize="12sp"
                    android:textColor="#FF9800" />

            </LinearLayout>

            <!-- 장보기 아이템 2 -->
            <LinearLayout
                android:id="@+id/shopping_item_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:elevation="2dp">

                <CheckBox
                    android:id="@+id/checkbox_item_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="계란 30개들이"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="유제품 • 약 8,000원"
                        android:textSize="12sp"
                        android:textColor="#666666" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="수량: 1개"
                    android:textSize="12sp"
                    android:textColor="#FF9800" />

            </LinearLayout>

            <!-- 장보기 아이템 3 -->
            <LinearLayout
                android:id="@+id/shopping_item_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:elevation="2dp">

                <CheckBox
                    android:id="@+id/checkbox_item_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:checked="true" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="양파 3개"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="채소 • 약 2,000원"
                        android:textSize="12sp"
                        android:textColor="#666666" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="완료!"
                    android:textSize="12sp"
                    android:textColor="#4CAF50" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 하단 액션 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btn_clear_completed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="완료 항목 삭제"
            android:backgroundTint="#F44336" />

        <Button
            android:id="@+id/btn_share_list"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="목록 공유"
            android:backgroundTint="#2196F3" />

    </LinearLayout>

</LinearLayout>