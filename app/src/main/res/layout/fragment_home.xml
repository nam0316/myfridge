<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 달력 아이콘 형태 날짜 표시 -->
        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <!-- 달력 상단 (년월) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:background="@drawable/calendar_top_bg"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_month_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="8sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="normal"
                    android:fontFamily="serif" />

            </LinearLayout>

            <!-- 달력 본체 (일, 요일) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:background="@drawable/calendar_bottom_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/tv_day"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="22sp"
                    android:textStyle="normal"
                    android:textColor="#2C2C2C"
                    android:layout_marginBottom="1dp"
                    android:fontFamily="serif"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tv_day_of_week"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="8sp"
                    android:textColor="#555555"
                    android:fontFamily="serif"
                    android:letterSpacing="0.1" />

            </LinearLayout>

        </LinearLayout>

        <!-- 냉장고 상태 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E3F2FD"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧊 냉장고 현황"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_fridge_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 보관중인 식재료: 12개\n• 유통기한 임박: 3개"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

        <!-- 오늘의 추천 레시피 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F3E5F5"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🍳 오늘의 추천 레시피"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_recommended_recipe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="김치찌개\n냉장고에 있는 김치와 돼지고기로 만들어보세요!"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>